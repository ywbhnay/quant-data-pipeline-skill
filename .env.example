# 量化数据管道 — 环境变量模板
# 复制为 .env 并填入真实值:
#   cp .env.example .env

# --------------------------------------------------------------------------- #
#  PostgreSQL 数据库
# --------------------------------------------------------------------------- #
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=quant_db
DB_USER=quant_user
DB_PASSWORD=your_password_here

# --------------------------------------------------------------------------- #
#  Tushare Pro API
# --------------------------------------------------------------------------- #
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_RATE_LIMIT=200

# --------------------------------------------------------------------------- #
#  告警通知 (可选，留空即不启用)
# --------------------------------------------------------------------------- #

# 企业微信机器人 Webhook URL
ALERT_WECOM_WEBHOOK=

# 钉钉机器人 Webhook URL
ALERT_DINGTALK_WEBHOOK=

# Telegram Bot
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
